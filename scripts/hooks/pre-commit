#!/bin/sh
# scripts/hooks/pre-commit
# Minimal pre-commit checks for Guardian AI
# Runs on both Linux (bash) and Windows (Git Bash)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0

echo "Running pre-commit checks..."

# 1. Check for trailing whitespace in staged C++ and header files
WHITESPACE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(hpp|cpp|h|c)$' | xargs -r grep -l '[[:blank:]]$' 2>/dev/null)
if [ -n "$WHITESPACE_FILES" ]; then
    echo "${RED}✗ Trailing whitespace found in:${NC}"
    echo "$WHITESPACE_FILES" | sed 's/^/    /'
    ERRORS=$((ERRORS + 1))
fi

# 2. Check for CRLF line endings in staged source files
CRLF_FILES=""
for f in $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(hpp|cpp|h|c|cmake|json|md)$'); do
    if [ -f "$f" ] && file "$f" | grep -q 'CRLF'; then
        CRLF_FILES="$CRLF_FILES $f"
    fi
done
if [ -n "$CRLF_FILES" ]; then
    echo "${YELLOW}⚠ CRLF line endings detected (should be LF):${NC}"
    echo "$CRLF_FILES" | tr ' ' '\n' | grep -v '^$' | sed 's/^/    /'
    echo "  Fix: git config core.autocrlf false && git add --renormalize ."
    ERRORS=$((ERRORS + 1))
fi

# 3. Check for files larger than 500KB (except .wasm binaries)
LARGE_FILES=""
for f in $(git diff --cached --name-only --diff-filter=ACM | grep -v '\.wasm$'); do
    if [ -f "$f" ]; then
        SIZE=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
        if [ "$SIZE" -gt 512000 ] 2>/dev/null; then
            LARGE_FILES="$LARGE_FILES $f (${SIZE} bytes)"
        fi
    fi
done
if [ -n "$LARGE_FILES" ]; then
    echo "${YELLOW}⚠ Large files detected (>500KB):${NC}"
    echo "$LARGE_FILES" | tr '(' '\n(' | grep -v '^$' | sed 's/^/    /'
    ERRORS=$((ERRORS + 1))
fi

# 4. Check that .hpp files have #pragma once
for f in $(git diff --cached --name-only --diff-filter=ACM | grep '\.hpp$'); do
    if [ -f "$f" ] && ! grep -q '#pragma once' "$f"; then
        echo "${RED}✗ Missing #pragma once in: $f${NC}"
        ERRORS=$((ERRORS + 1))
    fi
done

# 5. Check for debug leftover markers
DEBUG_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(hpp|cpp)$' | xargs -r grep -l 'FIXME\|HACK\|XXX' 2>/dev/null)
if [ -n "$DEBUG_FILES" ]; then
    echo "${YELLOW}⚠ Debug markers (FIXME/HACK/XXX) found in:${NC}"
    echo "$DEBUG_FILES" | sed 's/^/    /'
    # Warning only, don't block commit
fi

# Result
if [ $ERRORS -eq 0 ]; then
    echo "${GREEN}✓ All pre-commit checks passed${NC}"
    exit 0
else
    echo ""
    echo "${RED}✗ $ERRORS check(s) failed. Fix issues above or bypass with: git commit --no-verify${NC}"
    exit 1
fi
