# Guardian AI - Editor Configuration
# Ensures consistent formatting across all editors and OSes
# See https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,hpp,h,c}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[Makefile]
indent_style = tab

[*.{bat,cmd,ps1}]
end_of_line = crlf
